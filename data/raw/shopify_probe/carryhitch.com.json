   color: var(--muted);\n    }\n\n    main {\n      padding: 56px 0 24px;\n    }\n\n    h1 {\n      margin: 0 0 28px;\n      font-size: 42px;\n      line-height: 1.1;\n      letter-spacing: -0.03em;\n      font-weight: 700;\n    }\n\n    .post {\n      padding: 34px 0 44px;\n      border-bottom: 1px solid var(--border);\n    }\n\n    .post h2 {\n      margin: 0 0 16px;\n      font-size: 34px;\n      line-height: 1.15;\n      letter-spacing: -0.025em;\n      font-weight: 700;\n    }\n\n    .post h2 a {\n      text-decoration: none;\n    }\n\n    .entry-content {\n      color: #222;\n      font-size: 19px;\n      margin-bottom: 22px;\n    }\n\n    .post-date {\n      color: var(--muted);\n      font-size: 14px;\n    }\n\n    footer {\n      border-top: 1px solid var(--border);\n      margin-top: 48px;\n      padding: 56px 0 40px;\n      background: #fff;\n    }\n\n    .footer-grid {\n      display: grid;\n      grid-template-columns: 1.2fr 1fr 1fr;\n      gap: 28px;\n      align-items: start;\n    }\n\n    .footer-title {\n      margin: 0;\n      font-size: 30px;\n      line-height: 1.1;\n      font-weight: 700;\n      letter-spacing: -0.02em;\n    }\n\n    .footer-links {\n      list-style: none;\n      padding: 0;\n      margin: 0;\n      display: grid;\n      gap: 12px;\n      font-size: 15px;\n    }\n\n    .footer-links a {\n      text-decoration: none;\n      color: var(--muted);\n    }\n\n    .notice {\n      margin-top: 40px;\n      padding-top: 20px;\n      border-top: 1px solid var(--border);\n      color: var(--muted);\n      font-size: 14px;\n    }\n\n    @media (max-width: 820px) {\n      body { font-size: 17px; }\n      h1 { font-size: 36px; }\n      .post h2, .footer-title { font-size: 28px; }\n      .footer-grid { grid-template-columns: 1fr; }\n      .topbar { align-items: flex-start; padding: 18px 0; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div class=\"wide topbar\">\n      <a class=\"site-title\" href=\"#\">Web WP</a>\n      <nav class=